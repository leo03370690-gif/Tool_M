rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        ('email' in request.auth.token && request.auth.token.email == "leo03370690@gmail.com") ||
        ('email' in request.auth.token && request.auth.token.email == "leo.lo@tooling.local") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin')
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Type Validation Helpers
    // ===============================================================
    function checkStringLength(str, maxLen) {
      return str == null || (str is string && str.size() <= maxLen);
    }

    function isValidNumberOrString(val, maxLen) {
      return val == null || val is number || (val is string && val.size() <= maxLen);
    }

    function isValidBooleanStringNumber(val, maxLen) {
      return val == null || val is bool || val is number || (val is string && val.size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return checkStringLength(data.get('username', ''), 100) &&
             checkStringLength(data.get('email', ''), 100) &&
             (data.get('role', '') in ['admin', 'user', '']);
    }

    function isValidProduct(data) {
      return checkStringLength(data.get('device', ''), 200) &&
             checkStringLength(data.get('facility', ''), 200) &&
             checkStringLength(data.get('projectName', ''), 200) &&
             checkStringLength(data.get('nickname', ''), 200) &&
             checkStringLength(data.get('tester', ''), 200) &&
             checkStringLength(data.get('handler', ''), 200) &&
             checkStringLength(data.get('temperature', ''), 200) &&
             checkStringLength(data.get('insertion', ''), 200) &&
             checkStringLength(data.get('siteNumber', ''), 200) &&
             checkStringLength(data.get('ballCountDevice', ''), 200) &&
             checkStringLength(data.get('changeKitGroup', ''), 500) &&
             checkStringLength(data.get('kitName1', ''), 500) &&
             checkStringLength(data.get('kitName2', ''), 500) &&
             checkStringLength(data.get('kitName3', ''), 500) &&
             checkStringLength(data.get('kitName4', ''), 500) &&
             checkStringLength(data.get('lbGroup', ''), 500) &&
             checkStringLength(data.get('socketName1', ''), 500) &&
             checkStringLength(data.get('socketName2', ''), 500);
    }

    function isValidSocket(data) {
      return checkStringLength(data.get('toolsId', ''), 200) &&
             checkStringLength(data.get('facility', ''), 200) &&
             checkStringLength(data.get('package', ''), 200) &&
             checkStringLength(data.get('pinBall', ''), 200) &&
             checkStringLength(data.get('packageSize', ''), 200) &&
             checkStringLength(data.get('project', ''), 200) &&
             checkStringLength(data.get('status', ''), 200) &&
             isValidNumberOrString(data.get('contactCountPin1', 0), 50) &&
             isValidNumberOrString(data.get('lifeCountPin1', 0), 50) &&
             isValidNumberOrString(data.get('contactLimitPin1', 0), 50) &&
             checkStringLength(data.get('socketGroupPin1', ''), 200) &&
             isValidBooleanStringNumber(data.get('contactCountOver70Pin1', false), 50) &&
             checkStringLength(data.get('pogoPinPnPin1', ''), 200) &&
             checkStringLength(data.get('socketPnPin1', ''), 200) &&
             checkStringLength(data.get('usedFag', ''), 200) &&
             isValidNumberOrString(data.get('contactCountPin2', 0), 50) &&
             isValidNumberOrString(data.get('lifeCountPin2', 0), 50) &&
             isValidNumberOrString(data.get('contactLimitPin2', 0), 50) &&
             isValidBooleanStringNumber(data.get('contactCountOver70Pin2', false), 50) &&
             checkStringLength(data.get('pogoPinPnPin2', ''), 200) &&
             isValidNumberOrString(data.get('contactCountPcb', 0), 50) &&
             isValidNumberOrString(data.get('lifeCountPcb', 0), 50) &&
             isValidNumberOrString(data.get('contactLimitPcb', 0), 50) &&
             isValidBooleanStringNumber(data.get('contactCountOver70Pcb', false), 50) &&
             checkStringLength(data.get('pnPcb', ''), 200);
    }

    function isValidChangeKit(data) {
      return checkStringLength(data.get('kind', ''), 200) &&
             checkStringLength(data.get('facility', ''), 200) &&
             checkStringLength(data.get('toolsId', ''), 200) &&
             checkStringLength(data.get('packageSize', ''), 200) &&
             checkStringLength(data.get('changeKitGroup', ''), 200) &&
             checkStringLength(data.get('status', ''), 200) &&
             checkStringLength(data.get('idleTime', ''), 200);
    }

    function isValidPogoPin(data) {
      return checkStringLength(data.get('pinPn', ''), 200) &&
             checkStringLength(data.get('facility', ''), 200) &&
             isValidNumberOrString(data.get('qty', 0), 50);
    }

    function isValidLifeTime(data) {
      return checkStringLength(data.get('socketGroup', ''), 200) &&
             checkStringLength(data.get('facility', ''), 200) &&
             checkStringLength(data.get('pogoPin1Pn', ''), 200) &&
             isValidNumberOrString(data.get('pogoPinQty', 0), 50) &&
             checkStringLength(data.get('lifeTime', ''), 200) &&
             checkStringLength(data.get('loadBoardGroup', ''), 200) &&
             checkStringLength(data.get('remark', ''), 1000);
    }

    function isValidLoadBoard(data) {
      return checkStringLength(data.get('projectName', ''), 200) &&
             checkStringLength(data.get('lbName', ''), 200) &&
             checkStringLength(data.get('lbGroup', ''), 200) &&
             checkStringLength(data.get('location', ''), 200) &&
             checkStringLength(data.get('insertion', ''), 200) &&
             checkStringLength(data.get('availableQty', ''), 200) &&
             checkStringLength(data.get('remark', ''), 1000) &&
             checkStringLength(data.get('sendBackDate', ''), 200) &&
             checkStringLength(data.get('targetReturnDate', ''), 200);
    }

    function isValidRequiredPogoPinRow(data) {
      return checkStringLength(data.get('partNo', ''), 200) &&
             isValidNumberOrString(data.get('qty', 0), 50) &&
             checkStringLength(data.get('remark', ''), 1000) &&
             checkStringLength(data.get('facility', ''), 200) &&
             (!('pogoPins' in data) || data.pogoPins is list);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow update: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /sockets/{socketId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidSocket(request.resource.data);
      allow delete: if isAdmin();
    }

    match /changeKits/{kitId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidChangeKit(request.resource.data);
      allow delete: if isAdmin();
    }

    match /pogoPins/{pinId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidPogoPin(request.resource.data);
      allow delete: if isAdmin();
    }

    match /lifeTimes/{lifeTimeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidLifeTime(request.resource.data);
      allow delete: if isAdmin();
    }

    match /loadBoards/{loadBoardId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidLoadBoard(request.resource.data);
      allow delete: if isAdmin();
    }

    match /requiredPogoPinRows/{rowId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidRequiredPogoPinRow(request.resource.data);
      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      // Even admins shouldn't normally edit audit logs, but leaving write open to isAdmin per previous spec.
      // Should add a basic length check to prevent massive log bombs.
      allow write: if isAdmin() && checkStringLength(request.resource.data.get('action', ''), 500);
      allow delete: if isAdmin();
    }
  }
}
