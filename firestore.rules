rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         ('email' in request.auth.token && request.auth.token.email == "leo03370690@gmail.com") ||
         ('email' in request.auth.token && request.auth.token.email == "leo.lo@tooling.local"));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isOwner(userId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /sockets/{socketId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /changeKits/{kitId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /pogoPins/{pinId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /lifeTimes/{lifeTimeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /loadBoards/{loadBoardId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
